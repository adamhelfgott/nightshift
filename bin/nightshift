#!/usr/bin/env bash
# nightshift — an encrypted, multi-session, self-hosted work journal for AI coding agents.
# Universal core: harness-agnostic. Hooks that enforce it live in adapters/<harness>/.
set -euo pipefail

NS_HOME="${NIGHTSHIFT_HOME:-$HOME/.nightshift}"
ENTRIES="$NS_HOME/entries"
NOWISH="$NS_HOME/nowish.jsonl"
# resolve symlinks so LIB points at the real checkout (installer symlinks us into ~/.local/bin)
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  t="$(readlink "$SELF")"
  case "$t" in /*) SELF="$t";; *) SELF="$(dirname "$SELF")/$t";; esac
done
LIB="$(cd "$(dirname "$SELF")/../lib" && pwd)"

die(){ echo "nightshift: $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }
ts(){ date +%Y-%m-%dT%H:%M; }          # LOCAL time on purpose
day(){ date +%Y-%m-%d; }
uid(){ echo "m$(date +%s)$RANDOM"; }

cmd="${1:-help}"; shift || true

case "$cmd" in

init)
  mkdir -p "$ENTRIES"
  # journal is often git-inited; make sure the secret and the render never get committed
  # version what's been reviewed; never version the raw inbox, secrets, or the derivable render
  [ -f "$NS_HOME/.gitignore" ] || printf '.password\nindex.html\n.pending*\n.blocked*\nobservations.jsonl\n' > "$NS_HOME/.gitignore"
  if [ ! -f "$NS_HOME/config" ]; then
    # three questions, Enter accepts the default; silent (all defaults) without a tty
    title="Night Shift"; mirror=0; deploy=""
    if [ -t 0 ]; then
      printf "title for your page [Night Shift]: "; read -r a || true; [ -n "${a:-}" ] && title="$a"
      printf "observation register — may your agent privately log what it notices about YOU? (you review; never published) [y/N]: "
      read -r a || true; case "${a:-}" in y|Y|yes|YES) mirror=1;; esac
      printf "deploy command after render (blank = none, e.g. vercel --prod --yes): "; read -r a || true; deploy="${a:-}"
    fi
    cat > "$NS_HOME/config" <<EOF
# nightshift config
TITLE="$title"
GATE_SUBTITLE="burning the oil is members-only"
# DEPLOY_CMD runs after render (optional). Examples:
#   DEPLOY_CMD="vercel --prod --yes"
#   DEPLOY_CMD="netlify deploy --prod --dir=."
DEPLOY_CMD="$deploy"
# MIRROR=1 turns on the observation register: your agent may log observations
# ABOUT YOU (patterns, blind spots, calls worth revisiting) to a PRIVATE inbox
# that never appears on the shared page. Review with: nightshift mirror
MIRROR=$mirror
EOF
  fi
  if [ ! -f "$NS_HOME/.password" ]; then
    if [ -t 0 ]; then
      printf "Set a password to encrypt the published page (blank = no encryption): "
      read -rs pw; echo
      [ -n "$pw" ] && { umask 077; printf '%s' "$pw" > "$NS_HOME/.password"; echo "encryption on."; } || echo "encryption off (plain page)."
    else
      echo "non-interactive shell: encryption off (plain page). run 'nightshift init' in a terminal to add a password."
    fi
  fi
  echo "initialized $NS_HOME"
  cat <<EOF

first five minutes:
  nightshift log diary me "why I installed this"
  nightshift render                                # open $NS_HOME/index.html
  nightshift call me "I'll still be using this in two weeks" 60 $(date -v+14d +%Y-%m-%d 2>/dev/null || date -d '+14 days' +%Y-%m-%d 2>/dev/null || echo "")
EOF
  ;;

log)  # nightshift log <type> <session> "<text>"
  need jq
  typ="${1:?usage: nightshift log <type> <session> <text>}"; sess="${2:?session}"; text="${3:?text}"
  mkdir -p "$ENTRIES"
  jq -cn --arg ts "$(ts)" --arg s "$sess" --arg k "$typ" --arg t "$text" \
    '{ts:$ts,session:$s,type:$k,text:$t}' >> "$ENTRIES/$(day)-$sess.jsonl"
  echo "logged ($typ)"
  ;;

send) # nightshift send <from> <to|all> "<text>"
  need jq
  from="${1:?from}"; to="${2:?to}"; text="${3:?text}"
  jq -cn --arg id "$(uid)" --arg ts "$(ts)" --arg fr "$from" --arg to "$to" --arg t "$text" \
    '{kind:"msg",id:$id,ts:$ts,from:$fr,to:$to,text:$t}' >> "$NOWISH"
  echo "sent -> $to"
  ;;

pick) # nightshift pick <id> <by>
  need jq
  jq -cn --arg id "${1:?id}" --arg ts "$(ts)" --arg by "${2:?by}" '{kind:"pick",id:$id,ts:$ts,by:$by}' >> "$NOWISH"
  echo "picked ${1}"
  ;;

inbox) # nightshift inbox [session]
  [ -f "$NOWISH" ] || { echo "(no messages)"; exit 0; }
  NIGHTSHIFT_HOME="$NS_HOME" python3 "$LIB/inbox.py" "${1:-all}"
  ;;

call) # nightshift call <session> "<claim>" <confidence%> [due YYYY-MM-DD]  — log a falsifiable prediction
  need jq
  sess="${1:?usage: nightshift call <session> <claim> <confidence%> [due]}"; text="${2:?claim}"
  conf="${3:?confidence percent (e.g. 70)}"; due="${4:-}"
  case "$conf" in ''|*[!0-9]*) die "confidence must be an integer percent (0-100)";; esac
  id="$(uid)"
  jq -cn --arg id "$id" --arg ts "$(ts)" --arg s "$sess" --arg t "$text" --argjson c "$conf" --arg d "$due" \
    '{type:"call",id:$id,ts:$ts,session:$s,text:$t,conf:$c,due:$d}' >> "$ENTRIES/$(day)-$sess.jsonl"
  echo "call logged ($conf%) — score it later with: nightshift score $id right|wrong"
  ;;

due) # nightshift due — open calls whose due date has passed (the ones to chase)
  need jq
  today="$(day)"
  out=$(cat "$ENTRIES"/*.jsonl 2>/dev/null | jq -rs --arg today "$today" '
    (map(select(.type=="score") | .id)) as $done
    | map(select(.type=="call" and ((.id as $i | $done | index($i)) | not)))
    | map(select(.due != null and .due != "" and .due <= $today))
    | sort_by(.due)
    | .[] | "\(.id)  due \(.due)  \(.conf)%  \(.session): \(.text)"')
  [ -n "$out" ] && printf '%s\n' "$out" || echo "(nothing due)"
  ;;

score) # nightshift score <id> right|wrong
  need jq
  id="${1:?usage: nightshift score <id> right|wrong}"; v="${2:?right|wrong}"
  case "$v" in right|wrong) : ;; *) die "verdict must be 'right' or 'wrong'";; esac
  line=$(cat "$ENTRIES"/*.jsonl 2>/dev/null | jq -c --arg id "$id" 'select(.type=="call" and .id==$id)' | head -1)
  [ -n "$line" ] || die "no call with id $id"
  sess=$(printf '%s' "$line" | jq -r .session)
  jq -cn --arg id "$id" --arg ts "$(ts)" --arg s "$sess" --arg v "$v" \
    '{type:"score",id:$id,ts:$ts,session:$s,verdict:$v}' >> "$ENTRIES/$(day)-$sess.jsonl"
  echo "scored $v"
  ;;

observe) # nightshift observe <session> "<text>"  — an observation about your human collaborator
  need jq
  sess="${1:?usage: nightshift observe <session> <text>}"; text="${2:?text}"
  jq -cn --arg id "$(uid)" --arg ts "$(ts)" --arg s "$sess" --arg t "$text" \
    '{k:"obs",id:$id,ts:$ts,session:$s,text:$t}' >> "$NS_HOME/observations.jsonl"
  echo "observed (private — review with: nightshift mirror)"
  ;;

mirror) # nightshift mirror [keep <id>|drop <id>]  — review the private observation inbox
  need jq
  OBS="$NS_HOME/observations.jsonl"
  sub="${1:-list}"
  case "$sub" in
    deep)
      echo "# hand this to your agent in a fresh session: 'run this on me'"
      echo "# shareable: https://night-shift.sh/mirror   local: $LIB/../MIRROR.md"
      echo
      cat "$LIB/../MIRROR.md"
      ;;
    keep|drop)
      id="${2:?usage: nightshift mirror $sub <id>}"
      line=$(jq -c --arg id "$id" 'select(.k=="obs" and .id==$id)' "$OBS" 2>/dev/null | head -1)
      [ -n "$line" ] || die "no observation with id $id"
      if [ "$sub" = "keep" ]; then
        mkdir -p "$NS_HOME/mirror"
        [ -f "$NS_HOME/mirror.md" ] && mv "$NS_HOME/mirror.md" "$NS_HOME/mirror/kept.md"   # pre-0.5 migration
        printf -- "- %s (%s, %s)\n" "$(printf '%s' "$line" | jq -r .text)" \
          "$(printf '%s' "$line" | jq -r .session)" "$(printf '%s' "$line" | jq -r .ts)" >> "$NS_HOME/mirror/kept.md"
      fi
      jq -cn --arg id "$id" --arg ts "$(ts)" --arg v "$sub" '{k:"res",id:$id,ts:$ts,verdict:$v}' >> "$OBS"
      [ "$sub" = "keep" ] && echo "kept -> $NS_HOME/mirror/kept.md" || echo "dropped"
      ;;
    list|*)
      [ -f "$OBS" ] || { echo "(no observations)"; exit 0; }
      out=$(jq -rs '(map(select(.k=="res") | .id)) as $done
        | map(select(.k=="obs" and ((.id as $i | $done | index($i)) | not)))
        | .[] | "\(.id)  \(.ts)  \(.session): \(.text)"' "$OBS")
      [ -n "$out" ] && printf '%s\n' "$out" || echo "(inbox clear)"
      ;;
  esac
  ;;

open) # nightshift open [page|read|roadmap|kept|home|protocol|config]  — no arg: the index
  opener="open"; command -v xdg-open >/dev/null 2>&1 && opener="xdg-open"
  opener="${NIGHTSHIFT_OPENER:-$opener}"
  what="${1:-}"
  if [ -z "$what" ]; then
    echo "your nightshift, in one place:"
    printf '%s\n' \
      "page      $NS_HOME/index.html" \
      "read      $NS_HOME/mirror/read.md" \
      "roadmap   $NS_HOME/mirror/roadmap.md" \
      "kept      $NS_HOME/mirror/kept.md" \
      "config    $NS_HOME/config" \
      "home      $NS_HOME" \
      "protocol  $(cd "$LIB/.." && pwd)/MIRROR.md" \
    | while read -r k p; do
        if [ -e "$p" ]; then m="✓"; else m="·"; fi
        printf "  %s %-9s %s\n" "$m" "$k" "$p"
      done
    cat <<'EOF'
  nightshift open <name> opens it.  · = not made yet:
    page needs `nightshift render` · read/roadmap come from the protocol (nightshift mirror deep)
    kept comes from `nightshift mirror keep <id>`
EOF
    exit 0
  fi
  case "$what" in
    page)     tgt="$NS_HOME/index.html"
              [ -f "$tgt" ] || { need python3; NIGHTSHIFT_HOME="$NS_HOME" python3 "$LIB/render.py"; } ;;
    read)     tgt="$NS_HOME/mirror/read.md";;
    roadmap)  tgt="$NS_HOME/mirror/roadmap.md";;
    kept)     tgt="$NS_HOME/mirror/kept.md";;
    home)     tgt="$NS_HOME";;
    protocol) tgt="$(cd "$LIB/.." && pwd)/MIRROR.md";;
    config)   tgt="$NS_HOME/config";;
    *) die "unknown: $what (page|read|roadmap|kept|home|protocol|config)";;
  esac
  [ -e "$tgt" ] || die "$what doesn't exist yet — run 'nightshift open' for the index and how to make it"
  "$opener" "$tgt"
  ;;

render)
  need python3
  NIGHTSHIFT_HOME="$NS_HOME" python3 "$LIB/render.py"
  ;;

publish)
  need python3
  NIGHTSHIFT_HOME="$NS_HOME" python3 "$LIB/render.py"
  # the journal home is a repo — make its versioning real, not theoretical
  if [ -d "$NS_HOME/.git" ]; then
    git -C "$NS_HOME" add -A >/dev/null 2>&1 || true
    git -C "$NS_HOME" -c user.email=you@nightshift -c user.name=nightshift commit -qm "nightshift: $(ts)" >/dev/null 2>&1 || true
  fi
  # shellcheck disable=SC1091
  [ -f "$NS_HOME/config" ] && . "$NS_HOME/config"
  if [ -n "${DEPLOY_CMD:-}" ]; then ( cd "$NS_HOME" && eval "$DEPLOY_CMD" ); else
    echo "rendered $NS_HOME/index.html (set DEPLOY_CMD in $NS_HOME/config to auto-deploy)"; fi
  ;;

version)
  cat "$LIB/../VERSION" 2>/dev/null || echo "unknown"
  ;;

upgrade)
  SRCDIR="$(cd "$LIB/.." && pwd)"
  [ -d "$SRCDIR/.git" ] || die "not a git checkout ($SRCDIR) — re-run the installer: curl -fsSL https://night-shift.sh/install | bash"
  old="$(cat "$SRCDIR/VERSION" 2>/dev/null || echo '?')"
  git -C "$SRCDIR" pull --ff-only --quiet || die "could not fast-forward $SRCDIR — try: rm -rf $SRCDIR && curl -fsSL https://night-shift.sh/install | bash"
  new="$(cat "$SRCDIR/VERSION" 2>/dev/null || echo '?')"
  [ "$old" = "$new" ] && echo "already up to date ($new)" || echo "upgraded $old -> $new"
  ;;

doctor)
  echo "nightshift $(cat "$LIB/../VERSION" 2>/dev/null || echo unknown)"
  if [ -d "$LIB/../.git" ]; then
    git -C "$LIB/.." fetch --quiet 2>/dev/null || true
    behind=$(git -C "$LIB/.." rev-list --count HEAD..@{u} 2>/dev/null || echo 0)
    [ "${behind:-0}" -gt 0 ] && echo "  update available: $behind commit(s) behind — run: nightshift upgrade"
  fi
  echo "NIGHTSHIFT_HOME = $NS_HOME"
  for d in python3 jq date; do command -v "$d" >/dev/null 2>&1 && echo "  ok: $d" || echo "  MISSING: $d"; done
  python3 -c "import cryptography" 2>/dev/null && echo "  ok: python cryptography (encryption available)" || echo "  note: 'pip install cryptography' for encrypted pages"
  [ -f "$NS_HOME/.password" ] && echo "  encryption: ON" || echo "  encryption: off (plain page)"
  echo "  entries: $(ls "$ENTRIES" 2>/dev/null | wc -l | tr -d ' ') file(s)"
  ;;

help|*)
  cat <<EOF
nightshift — an encrypted, multi-session work journal for AI coding agents.

  nightshift init                         set up ~/.nightshift (or \$NIGHTSHIFT_HOME)
  nightshift log <type> <session> <text>  append an entry (type: shipped|diary|idea|learning|note|running)
  nightshift send <from> <to|all> <text>  send an inter-session (nowish) message
  nightshift inbox [session]              open messages for you / all
  nightshift pick <id> <by>               claim/ack a message
  nightshift observe <session> <text>     log an observation about your human (private)
  nightshift mirror [keep|drop <id>]      review that private inbox (never published)
  nightshift mirror deep                  print the Mirror Protocol (the full deep-read)
  nightshift call <sess> <claim> <conf%>  log a falsifiable prediction [due YYYY-MM-DD]
  nightshift score <id> right|wrong       score a call — the page tracks your hit rate
  nightshift due                          open calls past their due date
  nightshift render                       build the (encrypted) index.html
  nightshift open [what]                  index of everything it made; open one in a click
  nightshift publish                      render + commit the home + run DEPLOY_CMD
  nightshift doctor                       check deps, config & updates
  nightshift upgrade                      pull the latest nightshift
  nightshift version                      print the installed version

The diary is the point: log your thinking, not just what shipped.
EOF
  ;;
esac
